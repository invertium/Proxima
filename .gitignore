# Unreal Engine generated/build artifacts
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
*.VC.db
*.opensdf
*.sdf
*.suo
*.xcodeproj/
*.xcworkspace/

# Project files (regenerated)
.vs/
.vscode/
*.sln
Makefile
CMakeLists.txt
.ignore
compile_commands.json

# OS / editor cruft
.DS_Store
Thumbs.db

# --- Plugin local state (keep plugin source, drop their build/runtime junk) ---
Plugins/**/Binaries/
Plugins/**/Intermediate/

# Node bridge deps (reinstallable via npm install)
Plugins/UnrealClaude/UnrealClaude/Resources/mcp-bridge/node_modules/

# UnrealClaude auto-generated execute_script files (regenerated on demand)
Content/UnrealClaude/Scripts/

# Raw downloaded asset packs (imported copies live under Content/Art/)
_assets_dl/

# Secrets — never commit API keys
**/vibeue-proxy.json
*.apikey
.env

# Playwright MCP scratch (browser snapshots/screenshots)
.playwright-mcp/

# Packaged builds (BuildCookRun -archivedirectory output)
Packaged*/
